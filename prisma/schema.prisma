generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model BusTrafficSnapshot {
  id          Int      @id @default(autoincrement())
  stationId   Int
  stationName String
  area        String
  routeCount  Int
  activeCount Int
  avgCrowded  Float
  score       Int
  recordedAt  DateTime @default(now())

  @@index([stationId, recordedAt])
}
